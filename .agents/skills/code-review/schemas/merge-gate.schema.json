{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/schemas/code-review/merge-gate.schema.json",
  "title": "Deterministic merge-gate result",
  "type": "object",
  "required": ["schema_version", "snapshot_id", "decision", "decision_basis", "blockers"],
  "properties": {
    "schema_version": {"const": 1},
    "snapshot_id": {"type": "string", "minLength": 1},
    "decision": {"enum": ["ALLOW", "BLOCK"]},
    "decision_basis": {"enum": ["NORMAL_POLICY", "APPROVED_EXCEPTION", "EMERGENCY_POLICY"]},
    "blockers": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "owner", "required_action"],
        "properties": {
          "type": {"type": "string"},
          "owner": {"type": "string"},
          "required_action": {"type": "string"}
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
